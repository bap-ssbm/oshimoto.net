---

<button type="button" class="up-arrow-btn hover:scale-110 transition duration-500 hover:text-slate-200 px-[10%] pt-16" aria-label="Scroll to top">
  Back To Top
  <span class="inline-block text-[20px]">
    <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 19.5V4.5m0 0l-6 6m6-6l6 6" />
    </svg>
  </span>
</button>

<script>
  document.querySelector('.up-arrow-btn')?.addEventListener('click', () => {
    window.scrollTo({ top: 0, left: 0, behavior: 'smooth' });
  });
</script>
