---
interface Props {
  jpLabel: string;
  enTitle: string;
}

const { jpLabel, enTitle } = Astro.props;
---

<div data-section-heading>
  <p class="sect-jp font-noto-serif-jp text-[11px] md:text-[13px] tracking-[0.4em] text-[--color-warm-gray] mb-3" style="opacity: 0;">
    {jpLabel}
  </p>
  <h2 class="sect-title font-cormorant text-[36px] md:text-[56px] font-light tracking-[0.04em] leading-[1.1]" style="opacity: 0;">
    {enTitle}
  </h2>
  <div class="sect-line w-16 h-px bg-[--color-warm-gray]/40 mt-6 origin-left"></div>
</div>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const dur = (fallback: number) => prefersReduced ? 0.3 : fallback;

  document.querySelectorAll('[data-section-heading]').forEach((heading) => {
    const jp = heading.querySelector('.sect-jp');
    const title = heading.querySelector('.sect-title');
    const line = heading.querySelector('.sect-line');

    if (jp) {
      gsap.fromTo(jp,
        { x: 30, opacity: 0 },
        { x: 0, opacity: 1, duration: dur(0.8), ease: 'power2.out',
          scrollTrigger: { trigger: jp, start: 'top 88%', once: true } }
      );
    }
    if (title) {
      gsap.fromTo(title,
        { y: prefersReduced ? 0 : 60, opacity: 0, skewY: prefersReduced ? 0 : 2 },
        { y: 0, opacity: 1, skewY: 0, duration: dur(1.2), ease: 'power4.out',
          scrollTrigger: { trigger: title, start: 'top 85%', once: true } }
      );
    }
    if (line) {
      gsap.fromTo(line,
        { scaleX: 0 },
        { scaleX: 1, duration: dur(1), ease: 'power3.inOut',
          scrollTrigger: { trigger: line, start: 'top 85%', once: true } }
      );
    }
  });
</script>
