---
---

<div id="cursor" class="hidden md:block fixed top-0 left-0 z-[9998] pointer-events-none mix-blend-difference" style="opacity: 0;">
  <div id="cursor-dot" class="w-2 h-2 bg-cream rounded-full"></div>
</div>
<div id="cursor-ring" class="hidden md:block fixed top-0 left-0 z-[9997] pointer-events-none" style="opacity: 0;">
  <div class="w-10 h-10 border border-cream/30 rounded-full flex items-center justify-center transition-all duration-300">
    <span id="cursor-label" class="text-[9px] tracking-[0.2em] uppercase font-anonymous-pro text-cream/0 transition-all duration-300"></span>
  </div>
</div>

<script>
  import gsap from 'gsap';

  const isMobile = window.matchMedia('(max-width: 768px)').matches || 'ontouchstart' in window;
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!isMobile && !prefersReduced) {
    const cursor = document.getElementById('cursor');
    const cursorRing = document.getElementById('cursor-ring');
    const cursorLabel = document.getElementById('cursor-label');
    const ringInner = cursorRing?.firstElementChild as HTMLElement;

    if (cursor && cursorRing && cursorLabel && ringInner) {
      gsap.to([cursor, cursorRing], { opacity: 1, duration: 0.5, delay: 2.5 });

      let mouseX = 0;
      let mouseY = 0;

      document.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
      });

      // Smooth follow
      gsap.ticker.add(() => {
        gsap.to(cursor, { x: mouseX - 4, y: mouseY - 4, duration: 0.1, ease: 'power2.out' });
        gsap.to(cursorRing, { x: mouseX - 20, y: mouseY - 20, duration: 0.35, ease: 'power2.out' });
      });

      // Reset cursor to default state
      function resetCursor() {
        gsap.to(ringInner, { scale: 1, borderColor: 'rgba(232, 224, 212, 0.3)', duration: 0.3, ease: 'expo.out' });
        gsap.to(cursor.firstElementChild!, { scale: 1, duration: 0.3 });
      }

      // Grow on links/buttons
      const interactives = document.querySelectorAll('a, button');
      interactives.forEach((el) => {
        el.addEventListener('mouseenter', () => {
          gsap.to(ringInner, { scale: 1.6, borderColor: 'rgba(201, 169, 110, 0.5)', duration: 0.4, ease: 'expo.out' });
          gsap.to(cursor.firstElementChild!, { scale: 0.5, duration: 0.3 });
        });
        el.addEventListener('mouseleave', resetCursor);
      });

      // Safety net: reset cursor on scroll so it never gets stuck expanded
      let scrollResetTimer: ReturnType<typeof setTimeout>;
      window.addEventListener('scroll', () => {
        clearTimeout(scrollResetTimer);
        scrollResetTimer = setTimeout(resetCursor, 150);
      }, { passive: true });

      // Hide cursor when leaving window
      document.addEventListener('mouseleave', () => {
        gsap.to([cursor, cursorRing], { opacity: 0, duration: 0.3 });
        resetCursor();
      });
      document.addEventListener('mouseenter', () => {
        gsap.to([cursor, cursorRing], { opacity: 1, duration: 0.3 });
      });
    }
  }
</script>
