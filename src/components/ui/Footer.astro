---
import SocialIcons from './SocialIcons.astro';
import { SITE } from '../../data/site-config';
---

<footer class="px-[5%] md:px-[12%] pt-[120px] md:pt-[180px] pb-[50px] md:pb-[60px] relative overflow-hidden" data-footer>
  <div class="max-w-[1200px] mx-auto relative z-10">
    <div class="w-full h-px bg-[--color-warm-gray]/[0.06] mb-20"></div>

    <!-- Large decorative name -->
    <div class="overflow-hidden mb-14">
      <p data-footer-name class="font-cormorant text-[48px] md:text-[80px] lg:text-[120px] font-light tracking-[-0.03em] text-[--color-cream]/[0.08] leading-[1.0] whitespace-nowrap" style="opacity: 0;">
        Ryuichi Oshimoto
      </p>
    </div>

    <div class="flex flex-col md:flex-row md:justify-between gap-14">
      <div class="flex flex-col gap-10">
        <nav class="flex gap-8 text-[11px] tracking-[0.3em] uppercase" aria-label="Footer navigation">
          <a href="/portfolio/portraits" class="text-[--color-warm-gray]/40 hover:text-[--color-gold] transition-colors duration-500">Portfolio</a>
          <a href="/about" class="text-[--color-warm-gray]/40 hover:text-[--color-gold] transition-colors duration-500">About</a>
          <a href="/contact" class="text-[--color-warm-gray]/40 hover:text-[--color-gold] transition-colors duration-500">Inquire</a>
        </nav>
        <SocialIcons />
      </div>

      <div class="flex flex-col gap-4 md:text-end md:items-end">
        <p class="text-[11px] tracking-[0.2em] text-[--color-warm-gray]/25 font-anonymous-pro">
          Los Angeles · Hayama, Japan
        </p>
        <a href={`mailto:${SITE.email}`} class="text-[12px] text-[--color-cream]/30 hover:text-[--color-gold] transition-colors duration-500 font-cormorant tracking-[0.05em]">
          {SITE.email}
        </a>
        <p class="font-anonymous-pro text-[10px] text-[--color-warm-gray]/20 tracking-[0.1em] mt-2">
          &copy; {new Date().getFullYear()} · Available Worldwide
        </p>
      </div>
    </div>
  </div>
</footer>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const footerName = document.querySelector('[data-footer-name]');

  if (footerName && !prefersReduced) {
    gsap.fromTo(footerName,
      { opacity: 0 },
      {
        opacity: 1,
        duration: 1.5,
        ease: 'expo.out',
        scrollTrigger: { trigger: footerName, start: 'top 90%', once: true },
      }
    );
  } else if (footerName) {
    gsap.set(footerName, { opacity: 1 });
  }
</script>
