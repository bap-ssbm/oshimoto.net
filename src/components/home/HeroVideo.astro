---
---

<div class="relative min-h-[100svh]">
  <video
    id="hero-video"
    class="absolute inset-0 w-full h-full object-cover opacity-70"
    width="1920"
    height="1080"
    autoplay
    playsinline
    muted
    loop
    preload="none"
    poster="/images/poster_pc.jpg"
    aria-label="Background video showcasing photography work"
  >
    <source src="/video/20230129_CX取材.mp4" type="video/mp4" />
  </video>
  <!-- Fallback image shown until video plays -->
   <div id="hero-fallback" class="absolute inset-0 w-full h-full object-cover opacity-70">
    <img src="/images/poster_pc.jpg" alt="" width="1440" height="960" class="hidden md:block absolute inset-0 w-full h-full object-cover" fetchpriority="high" />
    <img src="/images/poster_sp.jpg" alt="" width="828" height="1242" class="block md:hidden absolute inset-0 w-full h-full object-cover" fetchpriority="high" />
   </div>
  
</div>

<script>
  const video = document.getElementById('hero-video') as HTMLVideoElement;
  const fallback = document.getElementById('hero-fallback') as HTMLElement;

  if (video && fallback) {
    const hideFallback = () => { fallback.style.display = 'none'; };
    video.addEventListener('playing', hideFallback, { once: true });

    // Start loading video after page is interactive
    const startVideo = () => {
      video.preload = 'auto';
      video.load();
      video.play().catch(() => {});
    };

    if (document.readyState === 'complete') {
      setTimeout(startVideo, 500);
    } else {
      window.addEventListener('load', () => setTimeout(startVideo, 500), { once: true });
    }

    // Touch to play on mobile
    document.body.addEventListener('touchstart', () => {
      if (video.paused) { video.preload = 'auto'; video.load(); video.play().catch(() => {}); }
    }, { once: true });
  }
</script>
