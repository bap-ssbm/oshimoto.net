---
---

<section class="py-[160px] md:py-[280px] px-[5%] md:px-[12%] relative overflow-hidden" data-cta-section>
  <!-- Ambient glow -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full bg-gold/[0.05] blur-[150px]"></div>
  </div>

  <div class="max-w-[900px] mx-auto text-center relative z-10">
    <p data-cta-el class="font-noto-serif-jp text-[11px] md:text-[12px] tracking-[0.6em] text-warm-gray/50 italic mb-6" style="opacity: 0;">
      お問い合わせ
    </p>

    <h2 data-cta-el class="font-cormorant text-[40px] md:text-[80px] lg:text-[100px] font-light tracking-[-0.03em] leading-[1.05]" style="opacity: 0;">
      Let's Create<br />Together
    </h2>

    <div data-cta-el class="w-16 h-px bg-gold/40 mx-auto mt-10 mb-12 origin-center" style="opacity: 0;"></div>

    <p data-cta-el class="text-[14px] md:text-[15px] text-cream/40 leading-[1.9] max-w-[480px] mx-auto mb-14" style="opacity: 0;">
      Whether it's a portrait session, landscape expedition, or commercial project — let's bring your vision to life.
    </p>

    <div data-cta-el style="opacity: 0;">
      <a
        href="/contact"
        class="group relative inline-flex items-center gap-4 px-10 py-5 border border-warm-gray/15 hover:border-gold/40 transition-all duration-700 overflow-hidden"
      >
        <span class="absolute inset-0 bg-gold/0 group-hover:bg-gold/[0.06] transition-colors duration-700"></span>
        <span class="relative text-[12px] md:text-[13px] tracking-[0.3em] uppercase font-brandon-grotesque text-cream/80 group-hover:text-gold transition-colors duration-500">
          Start a Conversation
        </span>
        <svg class="relative w-5 h-5 text-cream/40 group-hover:text-gold group-hover:translate-x-1 transition-all duration-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const section = document.querySelector('[data-cta-section]');

  if (section) {
    const elements = section.querySelectorAll('[data-cta-el]');
    elements.forEach((el, i) => {
      gsap.fromTo(el,
        { y: prefersReduced ? 0 : 40, opacity: 0 },
        {
          y: 0, opacity: 1,
          duration: prefersReduced ? 0.3 : 1,
          delay: prefersReduced ? 0 : i * 0.12,
          ease: 'expo.out',
          scrollTrigger: { trigger: el, start: 'top 85%', once: true },
        }
      );
    });
  }
</script>
