---
const images = [
  'https://lh3.googleusercontent.com/e1wcy3tMi8FSRybCaV7kBaujMrGedSk0mP19R_c5jYNAO5MeFNXeUi8Rm02YLoR_SNpl-36RevwW6rjxPZVePwpZ2MCunpbT3OWEiUJymnsU5RfHEIzu4ziUyFT2ShBbag8fb_nWEQ=w2400',
  'https://lh3.googleusercontent.com/NTPYhnXBjCXQwCIleufcheTywqgHkBCMw1JxVMT7ABkYbnHZ2hKHGW4wfNVIl0oLz4zVzkqzko_tTqhgr-izXIxBIij3q7bJjyR0AbX-Y_Rrx6L7hS7d3Ry-ds0l1qpKrxJ8g6Tfpw=w2400',
  'https://lh3.googleusercontent.com/K4ZypiR7ApqcmThsI0jV8yEuWDdrfgcHdhQAANpICrAjEWKS_B_N75zutA4-Qx9RrcXv4JQrfZ0LHeRJrLIAVm5Afdpt-kbILwGkXUI1mtpgic8RoKyElpqSsQvDx2fGY2_91ciANQ=w2400',
  'https://lh3.googleusercontent.com/TQUutEB9H2GZvBgYAMANbZV1BFg3j0sr65zJPetE961ld9mR58_uoJLb-oV0n84HfpeK-gdVZ1T7IJ9tKxwowa4MGYY8xsK2KjwLyfzG1mk-zp2jyjGxmU-aqMeaH3mtAcSGhuRbOA=w2400',
  'https://lh3.googleusercontent.com/WRu55IqCOblYVhECp62Ob00QMLiX1uyyMFuPi0TRhZHd-1RCE73lFc3gbR3HzK7Yp5ShXw_X_dBf4nh_1ObHPAsfc05oQoAe_dKm-_FB_AHO8rGUmx3n0VlWxAJO2xe738abpU7VVA=w2400',
  'https://lh3.googleusercontent.com/gAk68LCoGa-VQDIqGg8HyKIW6VdiOQfFkzOw-nz2ORQC10u2yUA9kclu90IZ9PeBYuZZ97SKlugYhjRNUoE0QFC1az6jrFZm9PBNYQWp99Q4X_bi64Oy4I7sE3mKKXSy-_USAnmI6g=w2400',
  'https://lh3.googleusercontent.com/EKWWaO45EUx6UJxYdIj-o2-4H9l3uYA_licguOPYr6IWR_DLe4WUP4W-h50kvMvjU9n3fhJ73AI6GQqaY3R9a0aliPuaatdw8VZ795dXBGshI0nQhPMr53wk8vJ7AniWECynF0mwZw=w2400',
];

const heights = ['55vh', '40vh', '60vh', '45vh', '55vh', '42vh', '58vh'];
const spHeights = ['45vh', '35vh', '50vh', '38vh', '45vh', '36vh', '48vh'];
const widths = ['32vw', '24vw', '28vw', '22vw', '30vw', '26vw', '28vw'];
const spWidths = ['65vw', '50vw', '58vw', '48vw', '62vw', '52vw', '56vw'];
const yOffsets = [20, -15, 25, -10, 18, -22, 15];
---

<section class="hscroll-section relative" data-hscroll>
  <div class="hscroll-pin h-screen flex items-center overflow-hidden">
    <div class="hscroll-track flex gap-6 md:gap-8 pl-[10vw]" data-hscroll-track>
      {images.map((src, i) => (
        <div
          class="hscroll-slide flex-shrink-0 overflow-hidden relative"
          data-sp-width={spWidths[i]}
          data-sp-height={spHeights[i]}
          data-y-offset={yOffsets[i]}
          style={`width: ${widths[i]}; height: ${heights[i]}; transform: translateY(${yOffsets[i]}px);`}
        >
          <img
            src={src}
            alt=""
            class="w-full h-full object-cover"
            style="filter: grayscale(0.4) sepia(0.1) brightness(0.85); transform: scale(1.1);"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-black-950/15"></div>
          <span class="absolute bottom-4 right-4 font-anonymous-pro text-[10px] text-cream/0 tracking-[0.1em]" data-slide-num>
            {String(i + 1).padStart(2, '0')}
          </span>
        </div>
      ))}
      <div class="flex-shrink-0 w-[10vw]"></div>
    </div>
  </div>

  <!-- Edge vignette -->
  <div class="absolute inset-0 pointer-events-none z-10 bg-gradient-to-r from-black-950 via-transparent to-black-950" style="opacity: 0.5;"></div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = window.matchMedia('(max-width: 768px)').matches;

  const section = document.querySelector('[data-hscroll]') as HTMLElement;
  const track = document.querySelector('[data-hscroll-track]') as HTMLElement;

  if (section && track) {
    if (isMobile) {
      track.querySelectorAll('.hscroll-slide').forEach((slide) => {
        const el = slide as HTMLElement;
        el.style.width = el.dataset.spWidth || '';
        el.style.height = el.dataset.spHeight || '';
      });
    }

    if (prefersReduced) {
      section.style.overflow = 'auto';
      const pin = section.querySelector('.hscroll-pin') as HTMLElement;
      if (pin) {
        pin.style.height = 'auto';
        pin.style.overflow = 'auto';
        pin.style.paddingTop = '3rem';
        pin.style.paddingBottom = '3rem';
      }
      track.style.paddingRight = '5vw';
      // Show images without filters
      track.querySelectorAll('.hscroll-slide img').forEach((img) => {
        (img as HTMLElement).style.filter = 'none';
      });
    } else {
      const totalScroll = track.scrollWidth - window.innerWidth;

      // Single clean horizontal scroll — tighter scrub for responsiveness
      gsap.to(track, {
        x: -totalScroll,
        ease: 'none',
        scrollTrigger: {
          trigger: section,
          start: 'top top',
          end: () => `+=${totalScroll}`,
          scrub: 0.3,
          pin: true,
          anticipatePin: 1,
          onUpdate: (self) => {
            // Colorize images as they pass through center viewport
            const slides = track.querySelectorAll('.hscroll-slide');
            const viewCenter = window.innerWidth / 2;

            slides.forEach((slide) => {
              const rect = slide.getBoundingClientRect();
              const slideCenter = rect.left + rect.width / 2;
              const distFromCenter = Math.abs(slideCenter - viewCenter);
              const maxDist = window.innerWidth * 0.6;
              const progress = Math.max(0, 1 - distFromCenter / maxDist);

              const img = slide.querySelector('img') as HTMLElement;
              const num = slide.querySelector('[data-slide-num]') as HTMLElement;
              if (img) {
                const gray = 0.4 - progress * 0.4;
                const bright = 0.85 + progress * 0.15;
                const sepia = 0.1 - progress * 0.1;
                img.style.filter = `grayscale(${gray}) sepia(${sepia}) brightness(${bright})`;
                img.style.transform = `scale(${1.1 - progress * 0.05})`;
              }
              if (num) {
                num.style.color = `rgba(232, 224, 212, ${progress * 0.4})`;
              }
            });
          },
        },
      });
    }
  }
</script>
