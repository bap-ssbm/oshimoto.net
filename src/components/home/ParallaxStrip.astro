---
// Mix from all 3 galleries: portrait, JP landscape, US landscape
const images = [
  // JP landscape
  'https://lh3.googleusercontent.com/6ZurmQdaMunZE3TKmq5Qns48_AFcWXALzWbXZhh1dsaAaqzICarUNM_QwejctxYYQzvqrBl-XniWT2k87pjl1S6RQKIy-dGsxftB1AA4QGeqjLu1X0CABcCj9adQxSMNe2_4YLBFvA=w2400',
  // Portrait
  'https://lh3.googleusercontent.com/qBk5E0g8ma7aDORpifeZeR9fgjQum82rwSl3ja9fT9stWbi-4Tr9xPePphlxa_bChKpBi-Rxy2Ddkt8OfteKXRUQjW1htD37jQMcq4lgnBZkyUGr1oJv1ogYnO9t4Z10a8BPGJblMA=w2400',
  // JP landscape
  'https://lh3.googleusercontent.com/rbqzg3DvSp54BML7fyX_gdBym8-lqKe2_yAYxvX26o3Efc4mXDc1MzHN3PB1TdmdJtLnPB5PkjFGodU44mrhSpMr-VrV-VzQo_ZdhKcqU4uYyMbJz8wWVyqK7-aTafiqqzC5inKS8A=w2400',
  // Portrait
  'https://lh3.googleusercontent.com/pw/AJFCJaUmZpz7_bY80mT4AEv3sAe5EedAlERU3Z47pIiz3e1OsPpczyYxcd9s2XH9u4zhSy92_2MoR555Z9uCNVSRxykp7FHhdGdSteHsxlt94HO3ZbmUqKk=w2400',
  // US landscape
  'https://lh3.googleusercontent.com/3GUSSJ_PC4P0Mi2n-hUGGe8zaUFfY1kLulXOQrTSQovFpUZcOTKKKRd1GEddCHVlejvsFb243ANmgvYVR50OVjsxK3UWthgDgEN-6NkfA1p-ZWvFD4o7iDQsi2ybJVJXgRpXp0XOdA=w2400',
  // JP landscape
  'https://lh3.googleusercontent.com/tMXDnvwg3drixaH28N3KqpexUmmP6QyyBx-sOpe28yxtdMTLsfj2tYQSE5RXvVBUfI0pwoRmNwb4nlYmyGCp0JrGwwH6bSCJ_-mSGy7YLY5pnbDLRu9A4xtuJtK-CqZD17-KKyT_pQ=w2400',
  // Portrait
  'https://lh3.googleusercontent.com/EKWWaO45EUx6UJxYdIj-o2-4H9l3uYA_licguOPYr6IWR_DLe4WUP4W-h50kvMvjU9n3fhJ73AI6GQqaY3R9a0aliPuaatdw8VZ795dXBGshI0nQhPMr53wk8vJ7AniWECynF0mwZw=w2400',
];

const widths =   ['35vw', '20vw', '32vw', '18vw', '36vw', '30vw', '22vw'];
const spWidths = ['70vw', '45vw', '65vw', '42vw', '72vw', '65vw', '48vw'];
---

<section class="hscroll-section relative" data-hscroll>
  <div class="hscroll-pin h-[100svh] flex items-center overflow-hidden">
    <div class="hscroll-track flex items-center gap-5 md:gap-7 pl-[10vw]" data-hscroll-track>
      {images.map((src, i) => (
        <div
          class="hscroll-slide flex-shrink-0 relative"
          data-sp-width={spWidths[i]}
          style={`width: ${widths[i]};`}
        >
          <img
            src={src}
            alt=""
            class="w-full object-cover block"
            style="height: 45svh; filter: grayscale(0.3) sepia(0.06) brightness(0.85);"
            loading="lazy"
          />
          <span class="absolute bottom-3 right-3 font-anonymous-pro text-[9px] text-cream/20 tracking-[0.1em]">
            {String(i + 1).padStart(2, '0')}
          </span>
        </div>
      ))}
      <div class="flex-shrink-0 w-[10vw]"></div>
    </div>
  </div>

  <div class="absolute inset-0 pointer-events-none z-10 bg-gradient-to-r from-black-950 via-transparent to-black-950" style="opacity: 0.5;"></div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = window.matchMedia('(max-width: 768px)').matches;

  const section = document.querySelector('[data-hscroll]') as HTMLElement;
  const track = document.querySelector('[data-hscroll-track]') as HTMLElement;

  if (section && track) {
    if (isMobile) {
      track.querySelectorAll('.hscroll-slide').forEach((slide) => {
        const el = slide as HTMLElement;
        el.style.width = el.dataset.spWidth || '';
      });
    }

    if (prefersReduced) {
      section.style.overflow = 'auto';
      const pin = section.querySelector('.hscroll-pin') as HTMLElement;
      if (pin) {
        pin.style.height = 'auto';
        pin.style.overflow = 'auto';
        pin.style.paddingTop = '3rem';
        pin.style.paddingBottom = '3rem';
      }
      track.style.paddingRight = '5vw';
      track.querySelectorAll('.hscroll-slide img').forEach((img) => {
        (img as HTMLElement).style.filter = 'none';
      });
    } else {
      const totalScroll = track.scrollWidth - window.innerWidth;

      gsap.to(track, {
        x: -totalScroll,
        ease: 'none',
        scrollTrigger: {
          trigger: section,
          start: 'top top',
          end: () => `+=${totalScroll}`,
          scrub: 0.5,
          pin: true,
          anticipatePin: 1,
        },
      });
    }
  }
</script>
