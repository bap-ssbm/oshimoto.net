---
import { SHOWCASE_IMAGES } from '../../data/site-config';
import SectionHeading from '../ui/SectionHeading.astro';

const JP_LABELS = ['人物', '北米風景', '日本風景'];
const MARQUEE_ITEMS = ['Portraits', 'Landscape', 'Editorial', 'Fine Art', 'Documentary', 'Commercial'];
---

<section id="showcase" class="pt-[120px] md:pt-[200px] pb-[60px] md:pb-[80px] relative">
  <div class="px-[5%] md:px-[12%] mb-20 md:mb-28">
    <SectionHeading jpLabel="作品" enTitle="Selected Work" />
  </div>

  <div class="px-[5%] md:px-[12%] relative">
    {SHOWCASE_IMAGES.map((item, i) => (
      <a
        data-showcase-row
        href={item.linkTo}
        class="group relative block border-t border-[--color-warm-gray]/[0.08] overflow-hidden"
      >
        {/* Background image — hidden by default, reveals on hover */}
        <div
          class="showcase-row-img absolute inset-0 z-0 overflow-hidden"
          data-img-src={item.imgURL}
        >
          <img
            src={item.imgURL}
            alt=""
            class="w-full h-full object-cover will-change-transform"
            style="scale: 1.1; filter: grayscale(0.2) brightness(0.7);"
            loading="lazy"
          />
        </div>

        {/* Content row */}
        <div class="relative z-10 flex items-center py-10 md:py-16">
          {/* Number */}
          <span class="font-anonymous-pro text-[12px] md:text-[14px] text-cream/50 group-hover:text-amber-300/60 transition-colors duration-700 tracking-[0.1em] w-[60px] md:w-[80px] flex-shrink-0">
            0{i + 1}
          </span>

          {/* Title */}
          <div class="flex-1">
            <h3 class="font-cormorant text-[36px] md:text-[72px] lg:text-[90px] font-normal tracking-[-0.03em] leading-[1.0] text-white/90 group-hover:text-white group-hover:tracking-[0.02em] transition-all duration-700">
              {item.label}
            </h3>
          </div>

          {/* JP label */}
          <div class="flex-shrink-0 flex items-center gap-6">
            <span class="hidden md:block font-noto-serif-jp text-[11px] tracking-[0.4em] text-warm-gray/40 group-hover:text-white/60 transition-colors duration-700 italic">
              {JP_LABELS[i]}
            </span>
          </div>
        </div>
      </a>
    ))}
    {/* Bottom border */}
    <div class="border-t border-[--color-warm-gray]/[0.08]"></div>
  </div>

  {/* Marquee */}
  <div data-showcase-marquee class="mt-[100px] md:mt-[160px] overflow-hidden border-y border-[--color-warm-gray]/[0.06] py-5" style="opacity: 0;">
    <div class="marquee-track flex whitespace-nowrap gap-16 text-[12px] md:text-[14px] tracking-[0.3em] uppercase text-[--color-warm-gray]/35 font-anonymous-pro">
      {[...MARQUEE_ITEMS, ...MARQUEE_ITEMS].map((text, i) => (
        <span>{i > 0 ? <>&nbsp;·&nbsp;&nbsp;{text}</> : text}</span>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const dur = (fallback: number) => prefersReduced ? 0.3 : fallback;

  // Row entrance animations
  document.querySelectorAll('[data-showcase-row]').forEach((row, i) => {
    gsap.fromTo(row,
      { opacity: 0 },
      {
        opacity: 1,
        duration: dur(2),
        delay: prefersReduced ? 0 : i * 0.15,
        ease: 'power1.out',
        scrollTrigger: { trigger: row, start: 'top 88%', once: true },
      }
    );

    // Background image — subtle scale on hover
    const imgBg = row.querySelector('.showcase-row-img') as HTMLElement;
    if (imgBg) {
      const img = imgBg.querySelector('img')!;

      row.addEventListener('mouseenter', () => {
        gsap.killTweensOf(img);
        gsap.to(img, { scale: 1.15, duration: 4, ease: 'power1.out' });
      });

      row.addEventListener('mouseleave', () => {
        gsap.killTweensOf(img);
        gsap.to(img, { scale: 1.1, duration: 1.2, ease: 'power2.out' });
      });
    }
  });

  // Marquee
  const marquee = document.querySelector('[data-showcase-marquee]');
  if (marquee) {
    gsap.fromTo(marquee,
      { opacity: 0 },
      { opacity: 1, duration: 2, ease: 'power1.out',
        scrollTrigger: { trigger: marquee, start: 'top 90%', once: true } }
    );
  }
</script>
