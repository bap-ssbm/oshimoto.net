---
import HeroVideo from './HeroVideo.astro';
import SocialIcons from '../ui/SocialIcons.astro';

const yearsActive = new Date().getFullYear() - 1984;
---

<div class="hero min-h-[100svh] relative overflow-hidden">
  <div class="relative" data-hero-parallax>
    <HeroVideo />
    <div data-hero-overlay class="absolute inset-0 bg-[--color-black-950]/60 z-[5]"></div>

    <div data-hero-content class="absolute w-full h-[100svh] top-0 z-10 px-[5%] flex flex-col justify-center items-center">
      <div class="text-center flex flex-col items-center">
        <p data-hero="jp" class="font-noto-serif-jp text-[16px] md:text-[18px] tracking-[0.3em] mb-6 text-black" style="opacity: 0;">
          押本龍一
        </p>
        <div data-hero="line" class="w-20 h-px bg-black/20 mb-6 origin-center" style="opacity: 0;"></div>
        <h1 data-hero="name" class="text-[42px] md:text-[76px] lg:text-[96px] font-cormorant font-normal tracking-[-0.02em] leading-[1.05] text-black" style="opacity: 0;">
          Ryuichi Oshimoto
        </h1>
        <p data-hero="subtitle" class="text-[14px] md:text-[16px] tracking-[0.3em] uppercase text-black mt-5 mb-2 font-brandon-grotesque" style="opacity: 0;">
          Los Angeles · Hayama, Japan
        </p>
        <p data-hero="avail" class="text-[10px] md:text-[11px] tracking-[0.35em] uppercase text-[--color-gold]/70 mb-10 font-anonymous-pro" style="opacity: 0;">
          Available Worldwide
        </p>
        <div data-hero="cta" class="flex flex-col items-center gap-8" style="opacity: 0;">
          <a class="btnAnimation flex gap-3 items-center w-fit text-[13px] md:text-[14px] uppercase tracking-[0.25em] font-brandon-grotesque text-black pb-1" href="/portfolio">
            View Work
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
            </svg>
          </a>
          <a class="text-[13px] md:text-[14px] uppercase tracking-[0.25em] font-brandon-grotesque text-black hover:text-[--color-gold] transition-colors duration-500 pb-1 border-b border-black/40 hover:border-amber-300/40" href="/contact">
            Inquire
          </a>
        </div>
      </div>

      <div data-hero="bottom" class="absolute bottom-10 w-full px-[5%] flex flex-col md:flex-row gap-5 md:gap-20 justify-end text-[13px] md:text-[15px] tracking-[0.1em] text-black/60" style="opacity: 0;">
        <div>
          <a href="#showcase" data-smooth-scroll class="dropDown flex gap-3 items-center w-fit text-black/80 hover:text-black transition-colors duration-500">
            Selected Work
            <svg class="svgIcon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
              <path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z" />
            </svg>
          </a>
        </div>
        <SocialIcons big />
      </div>
    </div>
  </div>
</div>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = window.matchMedia('(max-width: 768px)').matches;
  const $ = (sel: string) => document.querySelector(`[data-hero="${sel}"]`);

  // Smooth scroll for anchor links
  document.querySelectorAll('[data-smooth-scroll]').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.querySelector((link as HTMLAnchorElement).getAttribute('href')!);
      if (target) {
        target.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });

  if (prefersReduced) {
    gsap.to('[data-hero]', { opacity: 1, duration: 0.3 });
    const name = $('name');
    gsap.set($('name'), { opacity: 1 });
  } else {
    // Long delay only when preloader is visible (first visit in session)
    const preloaderVisible = !!document.getElementById('preloader');
    const tl = gsap.timeline({ delay: preloaderVisible ? 1.5 : 0.3 });

    // Clip-path reveal on the video background
    const parallaxLayer = document.querySelector('[data-hero-parallax]');
    if (parallaxLayer) {
      gsap.set(parallaxLayer, { clipPath: 'inset(100% 0 0 0)' });
      tl.to(parallaxLayer, { clipPath: 'inset(0% 0 0 0)', duration: 1.6, ease: 'power4.inOut' });
    }

    tl.fromTo($('jp'),
      { opacity: 0 },
      { opacity: 0.6, duration: 2, ease: 'power1.out' },
      '-=0.8'
    )
    .fromTo($('line'),
      { scaleX: 0, opacity: 0 },
      { scaleX: 1, opacity: 0.3, duration: 1.5, ease: 'power2.inOut' },
      '-=1.8'
    )
    .fromTo($('name'),
      { opacity: 0 },
      { opacity: 1, duration: 2.5, ease: 'power1.out' },
      '-=1.5'
    )
    .fromTo($('subtitle'),
      { opacity: 0 },
      { opacity: 1, duration: 2, ease: 'power1.out' },
      '-=2'
    )
    .fromTo($('avail'),
      { opacity: 0 },
      { opacity: 1, duration: 2, ease: 'power1.out' },
      '-=1.8'
    )
    .fromTo($('cta'),
      { opacity: 0 },
      { opacity: 1, duration: 2, ease: 'power1.out' },
      '-=1.8'
    )
    .fromTo($('bottom'),
      { opacity: 0 },
      { opacity: 1, duration: 2, ease: 'power1.out' },
      '-=1.8'
    );
  }

  // Scroll-linked effects (parallax, darken, content fade)
  if (!prefersReduced && !isMobile) {
    const heroSection = document.querySelector('.hero') as HTMLElement;
    const parallaxLayer = document.querySelector('[data-hero-parallax]') as HTMLElement;
    const overlay = document.querySelector('[data-hero-overlay]') as HTMLElement;
    const content = document.querySelector('[data-hero-content]') as HTMLElement;

    if (heroSection && parallaxLayer && overlay && content) {
      // Video parallax — moves slower than scroll
      gsap.to(parallaxLayer, {
        y: 200,
        ease: 'none',
        scrollTrigger: {
          trigger: heroSection,
          start: 'top top',
          end: 'bottom top',
          scrub: true,
        },
      });

      // Overlay darkens as you scroll past 80%
      gsap.to(overlay, {
        backgroundColor: 'rgba(245, 242, 237, 0.95)',
        ease: 'none',
        scrollTrigger: {
          trigger: heroSection,
          start: '60% top',
          end: 'bottom top',
          scrub: true,
        },
      });

      // Content fades out and drifts up
      gsap.to(content, {
        y: -80,
        opacity: 0,
        ease: 'none',
        scrollTrigger: {
          trigger: heroSection,
          start: '20% top',
          end: '80% top',
          scrub: true,
        },
      });
    }
  }
</script>
