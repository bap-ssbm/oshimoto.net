---
import Layout from '../../layouts/Layout.astro';
import PortfolioNav from '../../components/portfolio/PortfolioNav.astro';
import HomepageImage from '../../components/home/portfolio/HomepageImage';
import { SHOWCASE_IMAGES } from '../../data/site-config';
---

<Layout
  title="Portfolio - Ryuichi Oshimoto"
  description="Browse the photography portfolio of Ryuichi Oshimoto — portraits, North American landscapes, and Japanese landscapes."
  canonicalPath="/portfolio"
>
  <div class="pt-[100px] md:pt-[200px]">
    <PortfolioNav />
    <section class="py-[5%] flex flex-col gap-10 md:gap-16">
      {SHOWCASE_IMAGES.map((item) => (
        <HomepageImage
          client:visible
          imgURL={item.imgURL}
          linkTo={item.linkTo}
        >{item.label}</HomepageImage>
      ))}
    </section>
  </div>
</Layout>
