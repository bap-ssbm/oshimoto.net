---
import Layout from '../../layouts/Layout.astro';
import PortfolioNav from '../../components/portfolio/PortfolioNav.astro';
import Portfolio from '../../components/portfolio/Portfolio';
import { usPics } from '../../data/portfolio-data.js';
---

<Layout title="Americas Landscape - Ryuichi Oshimoto" description="American landscape photography by Ryuichi Oshimoto." canonicalPath="/portfolio/na-landscape">
  <main class="pt-[120px] md:pt-[160px]">
    <div class="text-center mb-8 px-[5%]">
      <p class="font-noto-serif-jp text-[11px] tracking-[0.6em] text-cream/50 mb-3">米州風景</p>
      <h1 class="font-cormorant text-[36px] md:text-[56px] font-light tracking-[-0.02em] mb-8">Americas</h1>
      <PortfolioNav />
    </div>
    <div class="mt-12">
      <Portfolio client:load imgData={usPics} />
    </div>
  </main>
</Layout>
