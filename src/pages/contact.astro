---
import Layout from '../layouts/Layout.astro';
import ContactImg from '../components/contact/ContactImg';
import Form from '../components/contact/Form';
import { SITE } from '../data/site-config';
---

<Layout
  title="Contact - Ryuichi Oshimoto"
  description="Get in touch with photographer Ryuichi Oshimoto for inquiries and collaborations."
  canonicalPath="/contact"
>
  <div class="px-[6%] pt-[200px] md:flex-row flex-col font-sans flex gap-20 max-w-[1400px] min-h-[60vh] mx-auto">
    <ContactImg client:load />
    <div class="flex-1 flex flex-col order-2">
      <h1 class="text-[25px] mb-20">Get in Touch!</h1>
      <Form client:load />
      <p class="text-lg mt-10 mb-10">
        or email me at <a href={`mailto:${SITE.email}`} class="underline">{SITE.email}</a>
      </p>
    </div>
  </div>
</Layout>
