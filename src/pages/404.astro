---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Not Found">
  <div class="w-full text-center min-h-[70vh] grid place-content-center px-[5%]">
    <p class="font-noto-serif-jp text-[11px] tracking-[0.6em] text-warm-gray/50 italic mb-5">ページが見つかりません</p>
    <h1 class="font-cormorant text-[48px] md:text-[72px] font-light tracking-[-0.02em] leading-[1.05] mb-8">404</h1>
    <p class="text-[14px] text-cream/40 mb-10">The page you're looking for doesn't exist.</p>
    <a href="/" class="text-[11px] tracking-[0.25em] uppercase text-gold/60 hover:text-gold transition-colors duration-500">Return Home</a>
  </div>
</Layout>
