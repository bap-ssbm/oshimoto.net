---
import '../styles/globals.css';
import Navbar from '../components/ui/navbar/Navbar';
import Footer from '../components/ui/Footer.astro';
import Preloader from '../components/ui/Preloader.astro';
import CustomCursor from '../components/ui/CustomCursor.astro';
import { SITE } from '../data/site-config';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalPath?: string;
}

const {
  title = SITE.title,
  description = SITE.description,
  ogImage = SITE.ogImage,
  canonicalPath,
} = Astro.props;

const canonicalURL = canonicalPath ? new URL(canonicalPath, SITE.url).toString() : undefined;
---

<html lang={SITE.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="referrer" content="no-referrer" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/images/ryuichi oshimoto white.png" />
    {canonicalURL && <link rel="canonical" href={canonicalURL} />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    {canonicalURL && <meta property="og:url" content={canonicalURL} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts: preconnect + non-blocking load -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&display=swap" media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;500;600&display=swap" media="print" onload="this.media='all'" />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&display=swap" />
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;500;600&display=swap" />
    </noscript>

    <title>{title}</title>
  </head>
  <body class="text-cream text-[15px] bg-black-950 font-brandon-grotesque antialiased">
    <Preloader />
    <CustomCursor />

    <!-- Scroll progress bar -->
    <div id="scroll-progress" class="fixed top-0 left-0 h-px bg-gold/60 z-[9990] origin-left" style="width: 100%; transform: scaleX(0);"></div>

    <Navbar client:load />
    <slot />
    <Footer />

    <script>
      import Lenis from 'lenis';
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const isMobile = window.matchMedia('(max-width: 768px)').matches || 'ontouchstart' in window;

      if (!prefersReduced && !isMobile) {
        const lenis = new Lenis({
          duration: 1.2,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        });

        lenis.on('scroll', ScrollTrigger.update);

        gsap.ticker.add((time) => {
          lenis.raf(time * 1000);
        });
        gsap.ticker.lagSmoothing(0);
      }

      // Scroll progress bar
      const progressBar = document.getElementById('scroll-progress');
      if (progressBar) {
        gsap.to(progressBar, {
          scaleX: 1,
          ease: 'none',
          scrollTrigger: {
            trigger: document.body,
            start: 'top top',
            end: 'bottom bottom',
            scrub: 0.3,
          },
        });
      }
    </script>
  </body>
</html>
